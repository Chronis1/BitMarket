}

.info {
    flex-wrap: wrap;
    width: 1100px;
    margin: 0px;
    display: flex ;
}

article {
    background-color: rgb(191, 194, 27);
    padding: 3px;
    width: 400px;
    margin: 3px;
}

.article-but {
    text-decoration: none;
    background-color: rgb(202, 32, 117);
    color: rgb(0, 0, 0);
    font-size: 24px;
    text-align: center;
    padding: 10px 75px 10px 75px;
}

